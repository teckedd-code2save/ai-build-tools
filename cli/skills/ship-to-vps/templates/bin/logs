#!/usr/bin/env bash
# Tail logs from the live {{slug}}-web container on the VPS.
#
# Usage:
#   bin/logs               # follow last 200 lines
#   bin/logs 500           # follow last 500 lines
#   bin/logs --since 10m   # entries from the last 10 minutes (no follow)
#   bin/logs db            # tail postgres instead of web
set -euo pipefail

VPS_HOST="${VPS_HOST:-{{vps_host}}}"
VPS_USER="${VPS_USER:-{{vps_user}}}"
SSH_KEY="${SSH_KEY:-$HOME/{{ssh_key_relpath}}}"

container="{{slug}}-web"
args=()

case "${1:-}" in
  db|postgres) container="{{slug}}-postgres"; shift ;;
esac

if [[ "${1:-}" == "--since" ]]; then
  shift
  args=(--since "${1:?--since requires a duration like 10m or 1h}")
  shift
elif [[ "${1:-}" =~ ^[0-9]+$ ]]; then
  args=(-f --tail="$1")
  shift
else
  args=(-f --tail=200)
fi

exec ssh -i "$SSH_KEY" -o StrictHostKeyChecking=accept-new "${VPS_USER}@${VPS_HOST}" \
  docker logs "${args[@]}" "$container"
